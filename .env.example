# Baza danych PostgreSQL (Neon lub Supabase)
# Neon: pooled connection string -> DATABASE_URL, unpooled -> DIRECT_URL
# Supabase: connection pooling string -> DATABASE_URL, direct connection -> DIRECT_URL
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Uzupełniane w kolejnych etapach:
# NEXTAUTH_SECRET=          (Etap 6)
# NEXTAUTH_URL=             (Etap 6)
# STRIPE_SECRET_KEY=        (Etap 5)
# STRIPE_WEBHOOK_SECRET=    (Etap 5)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= (Etap 5)
